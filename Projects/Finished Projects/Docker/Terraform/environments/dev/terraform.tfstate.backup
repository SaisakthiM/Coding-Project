    {
      "mode": "managed",
      "type": "helm_release",
      "name": "jaeger",
      "provider": "provider[\"registry.terraform.io/hashicorp/helm\"]",
      "instances": [
        {
          "schema_version": 1,
          "attributes": {
            "atomic": false,
            "chart": "jaeger",
            "cleanup_on_fail": false,
            "create_namespace": true,
            "dependency_update": false,
            "description": null,
            "devel": null,
            "disable_crd_hooks": false,
            "disable_openapi_validation": false,
            "disable_webhooks": false,
            "force_update": false,
            "id": "jaeger",
            "keyring": null,
            "lint": false,
            "manifest": null,
            "max_history": 0,
            "metadata": [
              {
                "app_version": "2.18.0",
                "chart": "jaeger",
                "first_deployed": 1780075612,
                "last_deployed": 1780075612,
                "name": "jaeger",
                "namespace": "monitoring",
                "notes": "###################################################################\n### ⚠️  EXPERIMENTAL - NO STABILITY GUARANTEES                  ###\n###                                                             ###\n### This chart is under active development.                     ###\n### Breaking changes may occur in minor versions.               ###\n###                                                             ###\n### See README.md for configuration details.                    ###\n###################################################################\n\n🚀 Congratulations on successfully installing Jaeger v2.18.0 (Chart v4.8.0)!\n\nTo access the query UI:\n  export POD_NAME=$(kubectl get pods --namespace monitoring -l \"app.kubernetes.io/instance=jaeger,app.kubernetes.io/component=all-in-one\" -o jsonpath=\"{.items[0].metadata.name}\")\n  kubectl port-forward --namespace monitoring $POD_NAME 16686:16686 --address 0.0.0.0 \u0026\n  Visit http://127.0.0.1:16686/\n",
                "revision": 1,
                "values": "{\"jaeger\":{\"enabled\":true},\"provisionDataStore\":{\"cassandra\":false,\"elasticsearch\":false,\"kafka\":false},\"serviceMonitor\":{\"additionalLabels\":{\"release\":\"kube-prometheus-stack\"},\"enabled\":true},\"storage\":{\"type\":\"memory\"},\"userconfig\":{\"exporters\":{\"jaeger_storage_exporter\":{\"trace_storage\":\"some_storage\"}},\"extensions\":{\"expvar\":{\"endpoint\":\"[::]:27777\"},\"healthcheckv2\":{\"http\":{\"endpoint\":\"0.0.0.0:13133\"},\"use_v2\":true},\"jaeger_mcp\":{\"http\":{\"endpoint\":\"0.0.0.0:16687\"}},\"jaeger_query\":{\"base_path\":\"/jaeger\",\"storage\":{\"traces\":\"some_storage\"}},\"jaeger_storage\":{\"backends\":{\"some_storage\":{\"memory\":{\"max_traces\":50000}}}},\"remote_sampling\":{\"file\":{\"path\":\"\"}},\"zpages\":{\"endpoint\":\"0.0.0.0:27778\"}},\"receivers\":{\"jaeger\":{\"protocols\":{\"grpc\":{\"endpoint\":\"0.0.0.0:14250\"},\"thrift_binary\":{\"endpoint\":\"0.0.0.0:6832\"},\"thrift_compact\":{\"endpoint\":\"0.0.0.0:6831\"},\"thrift_http\":{\"endpoint\":\"0.0.0.0:14268\"}}},\"otlp\":{\"protocols\":{\"grpc\":{\"endpoint\":\"0.0.0.0:4317\"},\"http\":{\"endpoint\":\"0.0.0.0:4318\"}}}},\"service\":{\"extensions\":[\"jaeger_storage\",\"jaeger_query\",\"healthcheckv2\",\"remote_sampling\",\"zpages\",\"expvar\",\"jaeger_mcp\"],\"pipelines\":{\"traces\":{\"exporters\":[\"jaeger_storage_exporter\"],\"receivers\":[\"otlp\",\"jaeger\"]}}}}}",
                "version": "4.8.0"
              }
            ],
            "name": "jaeger",
            "namespace": "monitoring",
            "pass_credentials": false,
            "postrender": [],
            "recreate_pods": false,
            "render_subchart_notes": true,
            "replace": false,
            "repository": "https://jaegertracing.github.io/helm-charts",
            "repository_ca_file": null,
            "repository_cert_file": null,
            "repository_key_file": null,
            "repository_password": null,
            "repository_username": null,
            "reset_values": false,
            "reuse_values": false,
            "set": [],
            "set_list": [],
            "set_sensitive": [],
            "skip_crds": false,
            "status": "deployed",
            "timeout": 180,
            "upgrade_install": null,
            "values": [
              "provisionDataStore:\n  cassandra: false\n  elasticsearch: false\n  kafka: false\n\nuserconfig:\n  service:\n    extensions: [jaeger_storage, jaeger_query, healthcheckv2, remote_sampling, zpages, expvar, jaeger_mcp]\n    pipelines:\n      traces:\n        receivers: [otlp, jaeger]\n        exporters: [jaeger_storage_exporter]\n\n  extensions:\n    healthcheckv2:\n      use_v2: true\n      http:\n        endpoint: 0.0.0.0:13133\n\n    jaeger_storage:\n      backends:\n        some_storage:\n          memory:\n            max_traces: 50000\n\n    jaeger_query:\n      storage:\n        traces: some_storage\n      base_path: /jaeger\n\n    remote_sampling:\n      file:\n        path: \"\"\n\n    zpages:\n      endpoint: 0.0.0.0:27778\n\n    expvar:\n      endpoint: \"[::]:27777\"\n\n    jaeger_mcp:\n      http:\n        endpoint: 0.0.0.0:16687\n\n  receivers:\n    otlp:\n      protocols:\n        grpc:\n          endpoint: 0.0.0.0:4317\n        http:\n          endpoint: 0.0.0.0:4318\n    jaeger:\n      protocols:\n        grpc:\n          endpoint: 0.0.0.0:14250\n        thrift_http:\n          endpoint: 0.0.0.0:14268\n        thrift_binary:\n          endpoint: 0.0.0.0:6832\n        thrift_compact:\n          endpoint: 0.0.0.0:6831\n\n  exporters:\n    jaeger_storage_exporter:\n      trace_storage: some_storage\n\njaeger:\n  enabled: true\n\nstorage:\n  type: memory\n\nserviceMonitor:\n  enabled: true\n  additionalLabels:\n    release: kube-prometheus-stack"
            ],
            "verify": false,
            "version": "4.8.0",
            "wait": true,
            "wait_for_jobs": false
          },
          "sensitive_attributes": [
            [
              {
                "type": "get_attr",
                "value": "repository_password"
              }
            ]
          ],
          "identity_schema_version": 0,
          "private": "eyJzY2hlbWFfdmVyc2lvbiI6IjEifQ==",
          "dependencies": [
            "helm_release.ingress_nginx",
            "helm_release.kube_prometheus_stack",
            "helm_release.loki",
            "helm_release.otel_collector",
            "helm_release.redis",
            "helm_release.tempo",
            "kubectl_manifest.cassandra_service",
            "kubectl_manifest.cassandra_statefulset",
            "kubectl_manifest.minio_service",
            "null_resource.kind_cluster"
          ]
        }
      ]
    },
    {
      "mode": "managed",
      "type": "helm_release",
      "name": "kube_prometheus_stack",
      "provider": "provider[\"registry.terraform.io/hashicorp/helm\"]",
      "instances": [
        {
          "schema_version": 1,
          "attributes": {
            "atomic": false,
            "chart": "kube-prometheus-stack",
            "cleanup_on_fail": false,
            "create_namespace": true,
            "dependency_update": false,
            "description": null,
            "devel": null,
            "disable_crd_hooks": false,
            "disable_openapi_validation": false,
            "disable_webhooks": false,
            "force_update": false,
            "id": "kube-prometheus-stack",
            "keyring": null,
            "lint": false,
            "manifest": null,
            "max_history": 0,
            "metadata": [
              {
                "app_version": "v0.91.0",
                "chart": "kube-prometheus-stack",
                "first_deployed": 1780120323,
                "last_deployed": 1780120323,
                "name": "kube-prometheus-stack",
                "namespace": "monitoring",
                "notes": "kube-prometheus-stack has been installed. Check its status by running:\n  kubectl --namespace monitoring get pods -l \"release=kube-prometheus-stack\"\n\nGet Grafana 'admin' user password by running:\n\n  kubectl --namespace monitoring get secrets kube-prometheus-stack-grafana -o jsonpath=\"{.data.admin-password}\" | base64 -d ; echo\n\nAccess Grafana local instance:\n\n  export POD_NAME=$(kubectl --namespace monitoring get pod -l \"app.kubernetes.io/name=grafana,app.kubernetes.io/instance=kube-prometheus-stack\" -oname)\n  kubectl --namespace monitoring port-forward $POD_NAME 3000\n\nGet your grafana admin user password by running:\n\n  kubectl get secret --namespace monitoring -l app.kubernetes.io/component=admin-secret -o jsonpath=\"{.items[0].data.admin-password}\" | base64 --decode ; echo\n\n\nVisit https://github.com/prometheus-operator/kube-prometheus for instructions on how to create \u0026 configure Alertmanager and Prometheus instances using the Operator.\n\nkube-state-metrics is a simple service that listens to the Kubernetes API server and generates metrics about the state of the objects.\nThe exposed metrics can be found here:\nhttps://github.com/kubernetes/kube-state-metrics/blob/master/docs/README.md#exposed-metrics\n\nThe metrics are exported on the HTTP endpoint /metrics on the listening port.\nIn your case, kube-prometheus-stack-kube-state-metrics.monitoring.svc.cluster.local:8080/metrics\n\nThey are served either as plaintext or protobuf depending on the Accept header.\nThey are designed to be consumed either by Prometheus itself or by a scraper that is compatible with scraping a Prometheus client endpoint.\n\n1. Get your 'admin' user password by running:\n\n   kubectl get secret --namespace monitoring kube-prometheus-stack-grafana -o jsonpath=\"{.data.admin-password}\" | base64 --decode ; echo\n\n\n2. The Grafana server can be accessed via port 80 on the following DNS name from within your cluster:\n\n   kube-prometheus-stack-grafana.monitoring.svc.cluster.local\n\n   Get the Grafana URL to visit by running these commands in the same shell:\n     export POD_NAME=$(kubectl get pods --namespace monitoring -l \"app.kubernetes.io/name=grafana,app.kubernetes.io/instance=kube-prometheus-stack\" -o jsonpath=\"{.items[0].metadata.name}\")\n     kubectl --namespace monitoring port-forward $POD_NAME 3000\n\n3. Login with the password from step 1 and the username: admin\n#################################################################################\n######   WARNING: Persistence is disabled!!! You will lose your data when   #####\n######            the Grafana pod is terminated.                            #####\n#################################################################################\n\n1. Get the application URL by running these commands:\n  export POD_NAME=$(kubectl get pods --namespace monitoring -l \"app.kubernetes.io/name=prometheus-node-exporter,app.kubernetes.io/instance=kube-prometheus-stack\" -o jsonpath=\"{.items[0].metadata.name}\")\n  echo \"Visit http://127.0.0.1:9100 to use your application\"\n  kubectl port-forward --namespace monitoring $POD_NAME 9100",
                "revision": 1,
                "values": "{\"defaultRules\":{\"disabled\":{\"node_namespace_pod_container:container_cpu_usage_seconds_total:sum_irate\":true,\"node_namespace_pod_container:container_memory_cache\":true,\"node_namespace_pod_container:container_memory_rss\":true,\"node_namespace_pod_container:container_memory_swap\":true,\"node_namespace_pod_container:container_memory_working_set_bytes\":true}},\"grafana\":{\"additionalDataSources\":[{\"access\":\"proxy\",\"jsonData\":{\"httpMethod\":\"POST\",\"timeInterval\":\"15s\"},\"name\":\"Prometheus\",\"type\":\"prometheus\",\"uid\":\"prometheus\",\"url\":\"http://kube-prometheus-stack-prometheus.monitoring.svc.cluster.local:9090\"},{\"access\":\"proxy\",\"jsonData\":{\"derivedFields\":[{\"datasourceUid\":\"tempo\",\"matcherRegex\":\"\\\"trace_id\\\":\\\"(\\\\w+)\\\"\",\"name\":\"TraceID\",\"url\":\"$${__value.raw}\"}]},\"name\":\"Loki\",\"type\":\"loki\",\"uid\":\"loki\",\"url\":\"http://loki-gateway.monitoring.svc.cluster.local\"},{\"access\":\"proxy\",\"jsonData\":{\"lokiSearch\":{\"datasourceUid\":\"loki\"},\"nodeGraph\":{\"enabled\":true},\"serviceMap\":{\"datasourceUid\":\"prometheus\"},\"tracesToLogsV2\":{\"datasourceUid\":\"loki\",\"filterBySpanID\":false,\"filterByTraceID\":true,\"tags\":[{\"key\":\"service.name\",\"value\":\"app\"}]},\"tracesToMetrics\":{\"datasourceUid\":\"prometheus\",\"queries\":[{\"name\":\"Request rate\",\"query\":\"rate(http_server_requests_seconds_count{app=\\\"$${__tags.app}\\\"}[5m])\"},{\"name\":\"Error rate\",\"query\":\"rate(http_server_requests_seconds_count{app=\\\"$${__tags.app}\\\",status=~\\\"5..\\\"}[5m])\"}],\"tags\":[{\"key\":\"service.name\",\"value\":\"app\"}]}},\"name\":\"Tempo\",\"type\":\"tempo\",\"uid\":\"tempo\",\"url\":\"http://tempo.monitoring.svc.cluster.local:3200\"},{\"access\":\"proxy\",\"jsonData\":{\"tracesToLogsV2\":{\"datasourceUid\":\"loki\",\"filterByTraceID\":true,\"tags\":[{\"key\":\"service.name\",\"value\":\"app\"}]}},\"name\":\"Jaeger\",\"type\":\"jaeger\",\"uid\":\"jaeger\",\"url\":\"http://jaeger.monitoring.svc.cluster.local:16686\"}],\"adminPassword\":\"admin\",\"grafana.ini\":{\"server\":{\"root_url\":\"%(protocol)s://%(domain)s/grafana/\",\"serve_from_sub_path\":true}},\"ingress\":{\"enabled\":false},\"resources\":{\"limits\":{\"cpu\":\"500m\",\"memory\":\"512Mi\"},\"requests\":{\"cpu\":\"100m\",\"memory\":\"128Mi\"}},\"securityContext\":{\"fsGroup\":472,\"runAsGroup\":472,\"runAsUser\":472}},\"prometheus\":{\"prometheusSpec\":{\"additionalScrapeConfigs\":[{\"job_name\":\"otel-collector-kind\",\"relabel_configs\":[{\"replacement\":\"otel-collector-kind\",\"target_label\":\"app\"},{\"replacement\":\"kind-social-media\",\"target_label\":\"cluster\"}],\"scrape_interval\":\"15s\",\"static_configs\":[{\"targets\":[\"otel-collector.monitoring.svc.cluster.local:8888\"]}]},{\"job_name\":\"jaeger\",\"relabel_configs\":[{\"replacement\":\"jaeger\",\"target_label\":\"app\"},{\"replacement\":\"kind-social-media\",\"target_label\":\"cluster\"}],\"scrape_interval\":\"15s\",\"static_configs\":[{\"targets\":[\"jaeger.monitoring.svc.cluster.local:8888\"]}]},{\"bearer_token_file\":\"/var/run/secrets/kubernetes.io/serviceaccount/token\",\"job_name\":\"kubernetes-cadvisor\",\"kubernetes_sd_configs\":[{\"role\":\"node\"}],\"relabel_configs\":[{\"action\":\"labelmap\",\"regex\":\"__meta_kubernetes_node_label_(.+)\"},{\"replacement\":\"kubernetes.default.svc:443\",\"target_label\":\"__address__\"},{\"regex\":\"(.+)\",\"replacement\":\"/api/v1/nodes/$1/proxy/metrics/cadvisor\",\"source_labels\":[\"__meta_kubernetes_node_name\"],\"target_label\":\"__metrics_path__\"},{\"replacement\":\"kind-social-media\",\"target_label\":\"cluster\"}],\"scheme\":\"https\",\"scrape_interval\":\"30s\",\"tls_config\":{\"ca_file\":\"/var/run/secrets/kubernetes.io/serviceaccount/ca.crt\",\"insecure_skip_verify\":true}}],\"enableRemoteWriteReceiver\":true,\"externalLabels\":{\"cluster\":\"kind-social-media\"},\"resources\":{\"limits\":{\"cpu\":\"1000m\",\"memory\":\"2Gi\"},\"requests\":{\"cpu\":\"200m\",\"memory\":\"512Mi\"}}}}}",
                "version": "86.1.0"
              }
            ],
            "name": "kube-prometheus-stack",
            "namespace": "monitoring",
            "pass_credentials": false,
            "postrender": [],
            "recreate_pods": false,
            "render_subchart_notes": true,
            "replace": false,
            "repository": "https://prometheus-community.github.io/helm-charts",
            "repository_ca_file": null,
            "repository_cert_file": null,
            "repository_key_file": null,
            "repository_password": null,
            "repository_username": null,
            "reset_values": false,
            "reuse_values": false,
            "set": [],
            "set_list": [],
            "set_sensitive": [],
            "skip_crds": false,
            "status": "deployed",
            "timeout": 600,
            "upgrade_install": null,
            "values": [
              "defaultRules:\n  disabled:\n    # These recording rules fail on multi-node kind clusters because\n    # kube_pod_info returns multiple matches when joining on\n    # (cluster, namespace, pod) across 3 worker nodes.\n    # Disabling them stops the \"multiple matches for labels\" WARN spam\n    # and unblocks the Grafana panels that depend on them.\n    node_namespace_pod_container:container_memory_cache: true\n    node_namespace_pod_container:container_memory_working_set_bytes: true\n    node_namespace_pod_container:container_memory_rss: true\n    node_namespace_pod_container:container_memory_swap: true\n    node_namespace_pod_container:container_cpu_usage_seconds_total:sum_irate: true\n\nprometheus:\n  prometheusSpec:\n    # Required so recording rules that join on `cluster` label\n    # find a consistent value across all scraped metrics.\n    externalLabels:\n      cluster: kind-social-media\n\n    enableRemoteWriteReceiver: true\n\n    additionalScrapeConfigs:\n      # ── 1. Kind-side OTel Collector self-metrics ──────────────\n      - job_name: otel-collector-kind\n        scrape_interval: 15s\n        static_configs:\n          - targets: [\"otel-collector.monitoring.svc.cluster.local:8888\"]\n        relabel_configs:\n          - target_label: app\n            replacement: otel-collector-kind\n          - target_label: cluster\n            replacement: kind-social-media\n\n      # ── 2. Jaeger self-metrics ────────────────────────────────\n      # FIX: service name is \"jaeger\" not \"jaeger-all-in-one\"\n      # FIX: metrics port for jaeger v2 is 8888 (otelcol internal),\n      #      not 14269 (that was jaeger v1 admin port)\n      - job_name: jaeger\n        scrape_interval: 15s\n        static_configs:\n          - targets: [\"jaeger.monitoring.svc.cluster.local:8888\"]\n        relabel_configs:\n          - target_label: app\n            replacement: jaeger\n          - target_label: cluster\n            replacement: kind-social-media\n\n      # ── 3. Kubernetes cAdvisor ────────────────────────────────\n      - job_name: kubernetes-cadvisor\n        scrape_interval: 30s\n        scheme: https\n        tls_config:\n          ca_file: /var/run/secrets/kubernetes.io/serviceaccount/ca.crt\n          insecure_skip_verify: true\n        bearer_token_file: /var/run/secrets/kubernetes.io/serviceaccount/token\n        kubernetes_sd_configs:\n          - role: node\n        relabel_configs:\n          - action: labelmap\n            regex: __meta_kubernetes_node_label_(.+)\n          - target_label: __address__\n            replacement: kubernetes.default.svc:443\n          - source_labels: [__meta_kubernetes_node_name]\n            regex: (.+)\n            target_label: __metrics_path__\n            replacement: /api/v1/nodes/$1/proxy/metrics/cadvisor\n          # FIX: add cluster label so join rules work\n          - target_label: cluster\n            replacement: kind-social-media",
              "grafana:\n  adminPassword: \"admin\"\n\n  grafana.ini:\n    server:\n      root_url: \"%(protocol)s://%(domain)s/grafana/\"\n      serve_from_sub_path: true\n\n  securityContext:\n    runAsUser: 472\n    runAsGroup: 472\n    fsGroup: 472\n\n  # FIX: removed sidecar.securityContext — forcing uid 472 on the\n  # k8s-sidecar image causes CrashLoopBackOff because that image\n  # runs as root by default and breaks on non-root uid.\n\n  ingress:\n    enabled: false\n\n  additionalDataSources:\n    - name: Prometheus\n      type: prometheus\n      uid: prometheus\n      url: http://kube-prometheus-stack-prometheus.monitoring.svc.cluster.local:9090\n      access: proxy\n      jsonData:\n        timeInterval: 15s\n        # POST is required for long PromQL queries — GET has URL length limits\n        httpMethod: POST\n\n    - name: Loki\n      type: loki\n      uid: loki\n      url: http://loki-gateway.monitoring.svc.cluster.local\n      access: proxy\n      jsonData:\n        derivedFields:\n          - name: TraceID\n            matcherRegex: '\"trace_id\":\"(\\w+)\"'\n            url: \"$${__value.raw}\"\n            datasourceUid: tempo\n\n    - name: Tempo\n      type: tempo\n      uid: tempo\n      url: http://tempo.monitoring.svc.cluster.local:3200\n      access: proxy\n      jsonData:\n        tracesToLogsV2:\n          datasourceUid: loki\n          tags:\n            - key: service.name\n              value: app\n          filterByTraceID: true\n          filterBySpanID: false\n        tracesToMetrics:\n          datasourceUid: prometheus\n          tags:\n            - key: service.name\n              value: app\n          queries:\n            - name: Request rate\n              query: 'rate(http_server_requests_seconds_count{app=\"$${__tags.app}\"}[5m])'\n            - name: Error rate\n              query: 'rate(http_server_requests_seconds_count{app=\"$${__tags.app}\",status=~\"5..\"}[5m])'\n        serviceMap:\n          datasourceUid: prometheus\n        nodeGraph:\n          enabled: true\n        lokiSearch:\n          datasourceUid: loki\n\n    - name: Jaeger\n      type: jaeger\n      uid: jaeger\n      # FIX: was jaeger-all-in-one.monitoring — that service does not exist.\n      # The chart creates a single service named \"jaeger\".\n      url: http://jaeger.monitoring.svc.cluster.local:16686\n      access: proxy\n      jsonData:\n        tracesToLogsV2:\n          datasourceUid: loki\n          tags:\n            - key: service.name\n              value: app\n          filterByTraceID: true\n\n  resources:\n    requests:\n      cpu: 100m\n      memory: 128Mi\n    limits:\n      cpu: 500m\n      memory: 512Mi",
              "\"prometheus\":\n  \"prometheusSpec\":\n    \"enableRemoteWriteReceiver\": true\n    \"resources\":\n      \"limits\":\n        \"cpu\": \"1000m\"\n        \"memory\": \"2Gi\"\n      \"requests\":\n        \"cpu\": \"200m\"\n        \"memory\": \"512Mi\"\n"
            ],
            "verify": false,
            "version": "86.1.0",
            "wait": true,
            "wait_for_jobs": false
          },
          "sensitive_attributes": [
            [
              {
                "type": "get_attr",
                "value": "repository_password"
              }
            ]
          ],
          "identity_schema_version": 0,
          "private": "eyJzY2hlbWFfdmVyc2lvbiI6IjEifQ==",
          "dependencies": [
            "helm_release.redis",
            "kubectl_manifest.cassandra_service",
            "kubectl_manifest.cassandra_statefulset",
            "null_resource.kind_cluster"
          ]
        }
      ]
    },
    {
      "mode": "managed",
      "type": "helm_release",
      "name": "loki",
      "provider": "provider[\"registry.terraform.io/hashicorp/helm\"]",
      "instances": [
        {
          "schema_version": 1,
          "attributes": {
            "atomic": false,
            "chart": "loki",
            "cleanup_on_fail": false,
            "create_namespace": true,
            "dependency_update": false,
            "description": null,
            "devel": null,
            "disable_crd_hooks": false,
            "disable_openapi_validation": false,
            "disable_webhooks": false,
            "force_update": false,
            "id": "loki",
            "keyring": null,
            "lint": false,
            "manifest": null,
            "max_history": 0,
            "metadata": [
              {
                "app_version": "3.6.7",
                "chart": "loki",
                "first_deployed": 1780075415,
                "last_deployed": 1780075415,
                "name": "loki",
                "namespace": "monitoring",
                "notes": "***********************************************************************\n Welcome to Grafana Loki\n Chart version: 7.0.0\n Chart Name: loki\n Loki version: 3.6.7\n***********************************************************************\n\n** Please be patient while the chart is being deployed **\n\nTip:\n\n  Watch the deployment status using the command: kubectl get pods -w --namespace monitoring\n\nIf pods are taking too long to schedule make sure pod affinity can be fulfilled in the current cluster.\n\n***********************************************************************\nInstalled components:\n***********************************************************************\n* loki\n\nLoki has been deployed as a single binary.\nThis means a single pod is handling reads and writes. You can scale that pod vertically by adding more CPU and memory resources.\n\n\n***********************************************************************\nSending logs to Loki\n***********************************************************************\n\nLoki has been configured with a gateway (nginx) to support reads and writes from a single component.\n\nYou can send logs from inside the cluster using the cluster DNS:\n\nhttp://loki-gateway.monitoring.svc.cluster.local/loki/api/v1/push\n\nYou can test to send data from outside the cluster by port-forwarding the gateway to your local machine:\n\n  kubectl port-forward --namespace monitoring svc/loki-gateway 3100:80 \u0026\n\nAnd then using http://127.0.0.1:3100/loki/api/v1/push URL as shown below:\n\n```\ncurl -H \"Content-Type: application/json\" -XPOST -s \"http://127.0.0.1:3100/loki/api/v1/push\"  \\\n--data-raw \"{\\\"streams\\\": [{\\\"stream\\\": {\\\"job\\\": \\\"test\\\"}, \\\"values\\\": [[\\\"$(date +%s)000000000\\\", \\\"fizzbuzz\\\"]]}]}\"\n```\n\nThen verify that Loki did receive the data using the following command:\n\n```\ncurl \"http://127.0.0.1:3100/loki/api/v1/query_range\" --data-urlencode 'query={job=\"test\"}' | jq .data.result\n```\n\n***********************************************************************\nConnecting Grafana to Loki\n***********************************************************************\n\nIf Grafana operates within the cluster, you'll set up a new Loki datasource by utilizing the following URL:\n\nhttp://loki-gateway.monitoring.svc.cluster.local/\n",
                "revision": 1,
                "values": "{\"backend\":{\"replicas\":0},\"chunksCache\":{\"enabled\":false},\"deploymentMode\":\"SingleBinary\",\"gateway\":{\"enabled\":true,\"replicas\":1,\"resources\":{\"limits\":{\"cpu\":\"200m\",\"memory\":\"128Mi\"},\"requests\":{\"cpu\":\"50m\",\"memory\":\"64Mi\"}}},\"loki\":{\"auth_enabled\":false,\"commonConfig\":{\"replication_factor\":1},\"limits_config\":{\"max_cache_freshness_per_query\":\"10m\",\"reject_old_samples\":true,\"reject_old_samples_max_age\":\"168h\",\"split_queries_by_interval\":\"15m\"},\"query_range\":{\"results_cache\":{\"cache\":{\"embedded_cache\":{\"enabled\":true,\"max_size_mb\":100}}}},\"schemaConfig\":{\"configs\":[{\"from\":\"2024-01-01\",\"index\":{\"period\":\"24h\",\"prefix\":\"loki_index_\"},\"object_store\":\"filesystem\",\"schema\":\"v13\",\"store\":\"tsdb\"}]},\"storage\":{\"type\":\"filesystem\"},\"storage_config\":{\"filesystem\":{\"directory\":\"/var/loki/chunks\"},\"tsdb_shipper\":{\"active_index_directory\":\"/var/loki/index\",\"cache_location\":\"/var/loki/index_cache\"}}},\"lokiCanary\":{\"enabled\":false},\"minio\":{\"enabled\":false},\"read\":{\"replicas\":0},\"resultsCache\":{\"enabled\":false},\"serviceMonitor\":{\"enabled\":true,\"labels\":{\"release\":\"kube-prometheus-stack\"}},\"singleBinary\":{\"replicas\":1,\"resources\":{\"limits\":{\"cpu\":\"500m\",\"memory\":\"512Mi\"},\"requests\":{\"cpu\":\"100m\",\"memory\":\"256Mi\"}}},\"test\":{\"enabled\":false},\"values_sha\":\"(sensitive value)\",\"write\":{\"replicas\":0}}",
                "version": "7.0.0"
              }
            ],
            "name": "loki",
            "namespace": "monitoring",
            "pass_credentials": false,
            "postrender": [],
            "recreate_pods": false,
            "render_subchart_notes": true,
            "replace": false,
            "repository": "https://grafana.github.io/helm-charts",
            "repository_ca_file": null,
            "repository_cert_file": null,
            "repository_key_file": null,
            "repository_password": null,
            "repository_username": null,
            "reset_values": false,
            "reuse_values": false,
            "set": [],
            "set_list": [],
            "set_sensitive": [
              {
                "name": "values_sha",
                "type": "",
                "value": "en3EsNgU5yJY1/1RpTUt1ekCzl6O7oB4IiIegsyZbwc="
              }
            ],
            "skip_crds": false,
            "status": "deployed",
            "timeout": 300,
            "upgrade_install": null,
            "values": [
              "# loki-config.yml — Helm values for grafana/loki\n\ndeploymentMode: SingleBinary\n\nloki:\n  auth_enabled: false\n\n  commonConfig:\n    replication_factor: 1\n\n  # Required since loki chart v3 — must be explicitly provided\n  schemaConfig:\n    configs:\n      - from: \"2024-01-01\"\n        store: tsdb\n        object_store: filesystem\n        schema: v13\n        index:\n          prefix: loki_index_\n          period: 24h\n\n  storage:\n    type: filesystem\n\n  storage_config:\n    tsdb_shipper:\n      active_index_directory: /var/loki/index\n      cache_location: /var/loki/index_cache\n    filesystem:\n      directory: /var/loki/chunks\n\n  limits_config:\n    reject_old_samples: true\n    reject_old_samples_max_age: 168h\n    max_cache_freshness_per_query: 10m\n    split_queries_by_interval: 15m\n\n  query_range:\n    results_cache:\n      cache:\n        embedded_cache:\n          enabled: true\n          max_size_mb: 100\n\nsingleBinary:\n  replicas: 1\n  resources:\n    requests:\n      cpu: 100m\n      memory: 256Mi\n    limits:\n      cpu: 500m\n      memory: 512Mi\n\n# Gateway gives promtail/otel a stable push endpoint\ngateway:\n  enabled: true\n  replicas: 1\n  resources:\n    requests:\n      cpu: 50m\n      memory: 64Mi\n    limits:\n      cpu: 200m\n      memory: 128Mi\n\n# Disable components not needed for single-binary mode\nbackend:\n  replicas: 0\nread:\n  replicas: 0\nwrite:\n  replicas: 0\n\nchunksCache:\n  enabled: false\nresultsCache:\n  enabled: false\n\n# Disable minio (use local filesystem instead)\nminio:\n  enabled: false\n\nserviceMonitor:\n  enabled: true\n  labels:\n    release: kube-prometheus-stack\n\ntest:\n  enabled: false\nlokiCanary:\n  enabled: false"
            ],
            "verify": false,
            "version": "7.0.0",
            "wait": true,
            "wait_for_jobs": false
          },
          "sensitive_attributes": [
            [
              {
                "type": "get_attr",
                "value": "repository_password"
              }
            ],
            [
              {
                "type": "get_attr",
                "value": "set_sensitive"
              }
            ]
          ],
          "identity_schema_version": 0,
          "private": "eyJzY2hlbWFfdmVyc2lvbiI6IjEifQ==",
          "dependencies": [
            "helm_release.kube_prometheus_stack",
            "helm_release.redis",
            "kubectl_manifest.cassandra_service",
            "kubectl_manifest.cassandra_statefulset",
            "null_resource.kind_cluster"
          ]
        }
      ]
    },
    {
      "mode": "managed",
      "type": "helm_release",
      "name": "otel_collector",
      "provider": "provider[\"registry.terraform.io/hashicorp/helm\"]",
      "instances": [
        {
          "schema_version": 1,
          "attributes": {
            "atomic": false,
            "chart": "opentelemetry-collector",
            "cleanup_on_fail": false,
            "create_namespace": true,
            "dependency_update": false,
            "description": null,
            "devel": null,
            "disable_crd_hooks": false,
            "disable_openapi_validation": false,
            "disable_webhooks": false,
            "force_update": false,
            "id": "otel-collector",
            "keyring": null,
            "lint": false,
            "manifest": null,
            "max_history": 0,
            "metadata": [
              {
                "app_version": "0.152.0",
                "chart": "opentelemetry-collector",
                "first_deployed": 1780075579,
                "last_deployed": 1780120680,
                "name": "otel-collector",
                "namespace": "monitoring",
                "notes": "\n\n\n[WARNING] config.service.telemetry.metrics.address should not be used and will be removed in the future. Use internalTelemetryViaOTLP or config.service.telemetry.metrics.readers  instead\"\n\n[DEPRECATION] Processor 'k8sattributes' has been renamed to 'k8s_attributes'. Update your values.yaml. See UPGRADING.md.\n[DEPRECATION] Pipeline 'logs' references renamed processor 'k8sattributes'. Use 'k8s_attributes' in your values.yaml. See UPGRADING.md.\n[DEPRECATION] Pipeline 'metrics' references renamed processor 'k8sattributes'. Use 'k8s_attributes' in your values.yaml. See UPGRADING.md.\n[DEPRECATION] Pipeline 'traces' references renamed processor 'k8sattributes'. Use 'k8s_attributes' in your values.yaml. See UPGRADING.md.\n\n",
                "revision": 2,
                "values": "{\"clusterRole\":{\"create\":true,\"rules\":[{\"apiGroups\":[\"\"],\"resources\":[\"pods\",\"namespaces\",\"nodes\",\"services\",\"endpoints\",\"replicationcontrollers\",\"resourcequotas\",\"persistentvolumes\",\"persistentvolumeclaims\"],\"verbs\":[\"get\",\"list\",\"watch\"]},{\"apiGroups\":[\"apps\"],\"resources\":[\"deployments\",\"replicasets\",\"statefulsets\",\"daemonsets\"],\"verbs\":[\"get\",\"list\",\"watch\"]},{\"apiGroups\":[\"autoscaling\"],\"resources\":[\"horizontalpodautoscalers\"],\"verbs\":[\"get\",\"list\",\"watch\"]},{\"apiGroups\":[\"batch\"],\"resources\":[\"jobs\",\"cronjobs\"],\"verbs\":[\"get\",\"list\",\"watch\"]}]},\"config\":{\"exporters\":{\"debug\":{\"sampling_initial\":5,\"sampling_thereafter\":200,\"verbosity\":\"basic\"},\"otlp/tempo\":{\"compression\":\"gzip\",\"endpoint\":\"http://tempo.monitoring.svc:4317\",\"tls\":{\"insecure\":true}},\"otlphttp/loki\":{\"endpoint\":\"http://loki-gateway.monitoring.svc.cluster.local/otlp\",\"tls\":{\"insecure\":true}},\"prometheusremotewrite\":{\"endpoint\":\"http://kube-prometheus-stack-prometheus.monitoring.svc:9090/api/v1/write\",\"resource_to_telemetry_conversion\":{\"enabled\":true},\"tls\":{\"insecure\":true}}},\"processors\":{\"batch\":{\"send_batch_max_size\":2048,\"send_batch_size\":1024,\"timeout\":\"5s\"},\"filter/drop_health\":{\"error_mode\":\"ignore\",\"metrics\":{\"metric\":[\"name == \\\"up\\\" and IsMatch(resource.attributes[\\\"job\\\"], \\\".*health.*\\\")\"]},\"traces\":{\"span\":[\"attributes[\\\"http.route\\\"] == \\\"/health\\\"\",\"attributes[\\\"http.route\\\"] == \\\"/healthz\\\"\",\"attributes[\\\"http.route\\\"] == \\\"/actuator/health\\\"\",\"attributes[\\\"http.route\\\"] == \\\"/metrics\\\"\"]}},\"k8sattributes\":{\"auth_type\":\"serviceAccount\",\"passthrough\":false},\"memory_limiter\":{\"check_interval\":\"5s\",\"limit_mib\":400,\"spike_limit_mib\":100},\"resource\":{\"attributes\":[{\"action\":\"insert\",\"key\":\"cluster\",\"value\":\"kind-social-media\"},{\"action\":\"insert\",\"key\":\"environment\",\"value\":\"local\"}]}},\"receivers\":{\"hostmetrics\":{\"collection_interval\":\"30s\",\"scrapers\":{\"cpu\":{},\"disk\":{},\"filesystem\":{},\"load\":{},\"memory\":{},\"network\":{},\"processes\":{}}},\"k8s_cluster\":{\"collection_interval\":\"30s\"},\"otlp\":{\"protocols\":{\"grpc\":{\"endpoint\":\"0.0.0.0:4317\"},\"http\":{\"cors\":{\"allowed_origins\":[\"*\"]},\"endpoint\":\"0.0.0.0:4318\"}}},\"prometheus\":{\"config\":{\"scrape_configs\":[{\"job_name\":\"otel-collector-self\",\"scrape_interval\":\"15s\",\"static_configs\":[{\"targets\":[\"localhost:8888\"]}]},{\"job_name\":\"ingress-nginx\",\"metrics_path\":\"/metrics\",\"relabel_configs\":[{\"replacement\":\"kind-social-media\",\"target_label\":\"cluster\"},{\"replacement\":\"ingress-nginx\",\"target_label\":\"app\"}],\"scrape_interval\":\"15s\",\"static_configs\":[{\"targets\":[\"ingress-nginx-controller.ingress-nginx.svc.cluster.local:10254\"]}]}]}}},\"service\":{\"pipelines\":{\"logs\":{\"exporters\":[\"otlphttp/loki\"],\"processors\":[\"memory_limiter\",\"k8sattributes\",\"resource\",\"batch\"],\"receivers\":[\"otlp\"]},\"metrics\":{\"exporters\":[\"prometheusremotewrite\"],\"processors\":[\"memory_limiter\",\"k8sattributes\",\"resource\",\"batch\"],\"receivers\":[\"otlp\",\"prometheus\",\"hostmetrics\",\"k8s_cluster\"]},\"traces\":{\"exporters\":[\"otlp/tempo\"],\"processors\":[\"memory_limiter\",\"k8sattributes\",\"resource\",\"filter/drop_health\",\"batch\"],\"receivers\":[\"otlp\"]}},\"telemetry\":{\"logs\":{\"level\":\"info\"},\"metrics\":{\"address\":\"0.0.0.0:8888\",\"level\":\"detailed\"}}}},\"extraEnvs\":[{\"name\":\"KUBE_NODE_NAME\",\"valueFrom\":{\"fieldRef\":{\"fieldPath\":\"spec.nodeName\"}}}],\"image\":{\"repository\":\"otel/opentelemetry-collector-contrib\",\"tag\":\"0.127.0\"},\"mode\":\"deployment\",\"ports\":{\"metrics\":{\"containerPort\":8888,\"enabled\":true,\"protocol\":\"TCP\",\"servicePort\":8888},\"otlp\":{\"containerPort\":4317,\"enabled\":true,\"protocol\":\"TCP\",\"servicePort\":4317},\"otlp-http\":{\"containerPort\":4318,\"enabled\":true,\"protocol\":\"TCP\",\"servicePort\":4318},\"prometheus\":{\"containerPort\":8889,\"enabled\":true,\"protocol\":\"TCP\",\"servicePort\":8889},\"zipkin\":{\"containerPort\":9411,\"enabled\":true,\"protocol\":\"TCP\",\"servicePort\":9411}},\"replicaCount\":1,\"resources\":{\"limits\":{\"cpu\":\"500m\",\"memory\":\"512Mi\"},\"requests\":{\"cpu\":\"100m\",\"memory\":\"256Mi\"}},\"serviceAccount\":{\"create\":true},\"serviceMonitor\":{\"enabled\":true,\"extraLabels\":{\"release\":\"kube-prometheus-stack\"},\"metricsEndpoints\":[{\"interval\":\"30s\",\"port\":\"metrics\"}]}}",
                "version": "0.157.2"
              }
            ],
            "name": "otel-collector",
            "namespace": "monitoring",
            "pass_credentials": false,
            "postrender": [],
            "recreate_pods": false,
            "render_subchart_notes": true,
            "replace": false,
            "repository": "https://open-telemetry.github.io/opentelemetry-helm-charts",
            "repository_ca_file": null,
            "repository_cert_file": null,
            "repository_key_file": null,
            "repository_password": null,
            "repository_username": null,
            "reset_values": false,
            "reuse_values": false,
            "set": [],
            "set_list": [],
            "set_sensitive": [],
            "skip_crds": false,
            "status": "deployed",
            "timeout": 300,
            "upgrade_install": null,
            "values": [
              "# otel-collector-values.yml — kind-side OTEL Collector\nmode: deployment\nreplicaCount: 1\n\nimage:\n  repository: otel/opentelemetry-collector-contrib\n  tag: \"0.127.0\"\n\nresources:\n  requests:\n    cpu: 100m\n    memory: 256Mi\n  limits:\n    cpu: 500m\n    memory: 512Mi\n\nports:\n  otlp:\n    enabled: true\n    containerPort: 4317\n    servicePort: 4317\n    protocol: TCP\n  otlp-http:\n    enabled: true\n    containerPort: 4318\n    servicePort: 4318\n    protocol: TCP\n  metrics:\n    enabled: true\n    containerPort: 8888\n    servicePort: 8888\n    protocol: TCP\n  zipkin:\n    enabled: true\n    containerPort: 9411\n    servicePort: 9411\n    protocol: TCP\n  prometheus:\n    enabled: true\n    containerPort: 8889\n    servicePort: 8889\n    protocol: TCP\n\nconfig:\n  receivers:\n    otlp:\n      protocols:\n        grpc:\n          endpoint: \"0.0.0.0:4317\"\n        http:\n          endpoint: \"0.0.0.0:4318\"\n          cors:\n            allowed_origins: [\"*\"]\n\n    prometheus:\n      config:\n        scrape_configs:\n          - job_name: otel-collector-self\n            scrape_interval: 15s\n            static_configs:\n              - targets: [\"localhost:8888\"]\n\n          - job_name: ingress-nginx\n            scrape_interval: 15s\n            metrics_path: /metrics\n            static_configs:\n              - targets: [\"ingress-nginx-controller.ingress-nginx.svc.cluster.local:10254\"]\n            relabel_configs:\n              - target_label: cluster\n                replacement: kind-social-media\n              - target_label: app\n                replacement: ingress-nginx\n\n    hostmetrics:\n      collection_interval: 30s\n      scrapers:\n        cpu: {}\n        memory: {}\n        disk: {}\n        filesystem: {}\n        network: {}\n        load: {}\n        processes: {}\n\n    k8s_cluster:\n      collection_interval: 30s\n\n  processors:\n    batch:\n      timeout: 5s\n      send_batch_size: 1024\n      send_batch_max_size: 2048\n\n    filter/drop_health:\n      error_mode: ignore\n      traces:\n        span:\n          - 'attributes[\"http.route\"] == \"/health\"'\n          - 'attributes[\"http.route\"] == \"/healthz\"'\n          - 'attributes[\"http.route\"] == \"/actuator/health\"'\n          - 'attributes[\"http.route\"] == \"/metrics\"'\n      metrics:\n        metric:\n          - 'name == \"up\" and IsMatch(resource.attributes[\"job\"], \".*health.*\")'\n\n    k8sattributes:\n      auth_type: serviceAccount\n      passthrough: false\n\n    resource:\n      attributes:\n        - key: cluster\n          value: kind-social-media\n          action: insert\n        - key: environment\n          value: local\n          action: insert\n\n    memory_limiter:\n      check_interval: 5s\n      limit_mib: 400\n      spike_limit_mib: 100\n\n  exporters:\n    prometheusremotewrite:\n      endpoint: http://kube-prometheus-stack-prometheus.monitoring.svc:9090/api/v1/write\n      tls:\n        insecure: true\n      resource_to_telemetry_conversion:\n        enabled: true\n\n    otlphttp/loki:\n      endpoint: http://loki-gateway.monitoring.svc.cluster.local/otlp\n      tls:\n        insecure: true\n\n    otlp/tempo:\n      endpoint: http://tempo.monitoring.svc:4317\n      tls:\n        insecure: true\n      compression: gzip\n\n    debug:\n      verbosity: basic\n      sampling_initial: 5\n      sampling_thereafter: 200\n\n  service:\n    telemetry:\n      logs:\n        level: info\n      metrics:\n        level: detailed\n        address: \"0.0.0.0:8888\"\n\n    pipelines:\n      traces:\n        receivers: [otlp]\n        processors: [memory_limiter, k8sattributes, resource, filter/drop_health, batch]\n        exporters: [otlp/tempo]\n\n      metrics:\n        receivers: [otlp, prometheus, hostmetrics, k8s_cluster]\n        processors: [memory_limiter, k8sattributes, resource, batch]\n        exporters: [prometheusremotewrite]\n\n      logs:\n        receivers: [otlp]\n        processors: [memory_limiter, k8sattributes, resource, batch]\n        exporters: [otlphttp/loki]\n\nclusterRole:\n  create: true\n  rules:\n    - apiGroups: [\"\"]\n      resources:\n        - pods\n        - namespaces\n        - nodes\n        - services\n        - endpoints\n        - replicationcontrollers\n        - resourcequotas\n        - persistentvolumes\n        - persistentvolumeclaims\n      verbs: [\"get\", \"list\", \"watch\"]\n    - apiGroups: [\"apps\"]\n      resources:\n        - deployments\n        - replicasets\n        - statefulsets\n        - daemonsets\n      verbs: [\"get\", \"list\", \"watch\"]\n    - apiGroups: [\"autoscaling\"]\n      resources:\n        - horizontalpodautoscalers\n      verbs: [\"get\", \"list\", \"watch\"]\n    - apiGroups: [\"batch\"]\n      resources:\n        - jobs\n        - cronjobs\n      verbs: [\"get\", \"list\", \"watch\"]\n\nserviceAccount:\n  create: true\n\nextraEnvs:\n  - name: KUBE_NODE_NAME\n    valueFrom:\n      fieldRef:\n        fieldPath: spec.nodeName\n\nserviceMonitor:\n  enabled: true\n  metricsEndpoints:\n    - port: metrics\n      interval: 30s\n  extraLabels:\n    release: kube-prometheus-stack"
            ],
            "verify": false,
            "version": "0.157.2",
            "wait": true,
            "wait_for_jobs": false
          },
          "sensitive_attributes": [
            [
              {
                "type": "get_attr",
                "value": "repository_password"
              }
            ]
          ],
          "identity_schema_version": 0,
          "private": "eyJzY2hlbWFfdmVyc2lvbiI6IjEifQ==",
          "dependencies": [
            "helm_release.kube_prometheus_stack",
            "helm_release.loki",
            "helm_release.redis",
            "helm_release.tempo",
            "kubectl_manifest.cassandra_service",
            "kubectl_manifest.cassandra_statefulset",
            "kubectl_manifest.minio_service",
            "null_resource.kind_cluster"
          ]
        }
      ]
    },
