            "keyring": null,
            "lint": false,
            "manifest": null,
            "max_history": 0,
            "metadata": [
              {
                "app_version": "3.6.7",
                "chart": "loki",
                "first_deployed": 1779946489,
                "last_deployed": 1779946489,
                "name": "loki",
                "namespace": "monitoring",
                "notes": "***********************************************************************\n Welcome to Grafana Loki\n Chart version: 7.0.0\n Chart Name: loki\n Loki version: 3.6.7\n***********************************************************************\n\n** Please be patient while the chart is being deployed **\n\nTip:\n\n  Watch the deployment status using the command: kubectl get pods -w --namespace monitoring\n\nIf pods are taking too long to schedule make sure pod affinity can be fulfilled in the current cluster.\n\n***********************************************************************\nInstalled components:\n***********************************************************************\n* loki\n\nLoki has been deployed as a single binary.\nThis means a single pod is handling reads and writes. You can scale that pod vertically by adding more CPU and memory resources.\n\n\n***********************************************************************\nSending logs to Loki\n***********************************************************************\n\nLoki has been configured with a gateway (nginx) to support reads and writes from a single component.\n\nYou can send logs from inside the cluster using the cluster DNS:\n\nhttp://loki-gateway.monitoring.svc.cluster.local/loki/api/v1/push\n\nYou can test to send data from outside the cluster by port-forwarding the gateway to your local machine:\n\n  kubectl port-forward --namespace monitoring svc/loki-gateway 3100:80 \u0026\n\nAnd then using http://127.0.0.1:3100/loki/api/v1/push URL as shown below:\n\n```\ncurl -H \"Content-Type: application/json\" -XPOST -s \"http://127.0.0.1:3100/loki/api/v1/push\"  \\\n--data-raw \"{\\\"streams\\\": [{\\\"stream\\\": {\\\"job\\\": \\\"test\\\"}, \\\"values\\\": [[\\\"$(date +%s)000000000\\\", \\\"fizzbuzz\\\"]]}]}\"\n```\n\nThen verify that Loki did receive the data using the following command:\n\n```\ncurl \"http://127.0.0.1:3100/loki/api/v1/query_range\" --data-urlencode 'query={job=\"test\"}' | jq .data.result\n```\n\n***********************************************************************\nConnecting Grafana to Loki\n***********************************************************************\n\nIf Grafana operates within the cluster, you'll set up a new Loki datasource by utilizing the following URL:\n\nhttp://loki-gateway.monitoring.svc.cluster.local/\n",
                "revision": 1,
                "values": "{\"backend\":{\"replicas\":0},\"chunksCache\":{\"enabled\":false},\"deploymentMode\":\"SingleBinary\",\"gateway\":{\"enabled\":true,\"replicas\":1,\"resources\":{\"limits\":{\"cpu\":\"200m\",\"memory\":\"128Mi\"},\"requests\":{\"cpu\":\"50m\",\"memory\":\"64Mi\"}}},\"loki\":{\"auth_enabled\":false,\"commonConfig\":{\"replication_factor\":1},\"limits_config\":{\"max_cache_freshness_per_query\":\"10m\",\"reject_old_samples\":true,\"reject_old_samples_max_age\":\"168h\",\"split_queries_by_interval\":\"15m\"},\"query_range\":{\"results_cache\":{\"cache\":{\"embedded_cache\":{\"enabled\":true,\"max_size_mb\":100}}}},\"schemaConfig\":{\"configs\":[{\"from\":\"2024-01-01\",\"index\":{\"period\":\"24h\",\"prefix\":\"loki_index_\"},\"object_store\":\"filesystem\",\"schema\":\"v13\",\"store\":\"tsdb\"}]},\"storage\":{\"type\":\"filesystem\"},\"storage_config\":{\"filesystem\":{\"directory\":\"/var/loki/chunks\"},\"tsdb_shipper\":{\"active_index_directory\":\"/var/loki/index\",\"cache_location\":\"/var/loki/index_cache\"}}},\"lokiCanary\":{\"enabled\":false},\"minio\":{\"enabled\":false},\"read\":{\"replicas\":0},\"resultsCache\":{\"enabled\":false},\"serviceMonitor\":{\"enabled\":true,\"labels\":{\"release\":\"kube-prometheus-stack\"}},\"singleBinary\":{\"replicas\":1,\"resources\":{\"limits\":{\"cpu\":\"500m\",\"memory\":\"512Mi\"},\"requests\":{\"cpu\":\"100m\",\"memory\":\"256Mi\"}}},\"test\":{\"enabled\":false},\"values_sha\":\"(sensitive value)\",\"write\":{\"replicas\":0}}",
                "version": "7.0.0"
              }
            ],
            "name": "loki",
            "namespace": "monitoring",
            "pass_credentials": false,
            "postrender": [],
            "recreate_pods": false,
            "render_subchart_notes": true,
            "replace": false,
            "repository": "https://grafana.github.io/helm-charts",
            "repository_ca_file": null,
            "repository_cert_file": null,
            "repository_key_file": null,
            "repository_password": null,
            "repository_username": null,
            "reset_values": false,
            "reuse_values": false,
            "set": [],
            "set_list": [],
            "set_sensitive": [
              {
                "name": "values_sha",
                "type": "",
                "value": "en3EsNgU5yJY1/1RpTUt1ekCzl6O7oB4IiIegsyZbwc="
              }
            ],
            "skip_crds": false,
            "status": "deployed",
            "timeout": 300,
            "upgrade_install": null,
            "values": [
              "# loki-config.yml — Helm values for grafana/loki\n\ndeploymentMode: SingleBinary\n\nloki:\n  auth_enabled: false\n\n  commonConfig:\n    replication_factor: 1\n\n  # Required since loki chart v3 — must be explicitly provided\n  schemaConfig:\n    configs:\n      - from: \"2024-01-01\"\n        store: tsdb\n        object_store: filesystem\n        schema: v13\n        index:\n          prefix: loki_index_\n          period: 24h\n\n  storage:\n    type: filesystem\n\n  storage_config:\n    tsdb_shipper:\n      active_index_directory: /var/loki/index\n      cache_location: /var/loki/index_cache\n    filesystem:\n      directory: /var/loki/chunks\n\n  limits_config:\n    reject_old_samples: true\n    reject_old_samples_max_age: 168h\n    max_cache_freshness_per_query: 10m\n    split_queries_by_interval: 15m\n\n  query_range:\n    results_cache:\n      cache:\n        embedded_cache:\n          enabled: true\n          max_size_mb: 100\n\nsingleBinary:\n  replicas: 1\n  resources:\n    requests:\n      cpu: 100m\n      memory: 256Mi\n    limits:\n      cpu: 500m\n      memory: 512Mi\n\n# Gateway gives promtail/otel a stable push endpoint\ngateway:\n  enabled: true\n  replicas: 1\n  resources:\n    requests:\n      cpu: 50m\n      memory: 64Mi\n    limits:\n      cpu: 200m\n      memory: 128Mi\n\n# Disable components not needed for single-binary mode\nbackend:\n  replicas: 0\nread:\n  replicas: 0\nwrite:\n  replicas: 0\n\nchunksCache:\n  enabled: false\nresultsCache:\n  enabled: false\n\n# Disable minio (use local filesystem instead)\nminio:\n  enabled: false\n\nserviceMonitor:\n  enabled: true\n  labels:\n    release: kube-prometheus-stack\n\ntest:\n  enabled: false\nlokiCanary:\n  enabled: false"
            ],
            "verify": false,
            "version": "7.0.0",
            "wait": true,
            "wait_for_jobs": false
          },
          "sensitive_attributes": [
            [
              {
                "type": "get_attr",
                "value": "repository_password"
              }
            ],
            [
              {
                "type": "get_attr",
                "value": "set_sensitive"
              }
            ]
          ],
          "identity_schema_version": 0,
          "private": "eyJzY2hlbWFfdmVyc2lvbiI6IjEifQ==",
          "dependencies": [
            "helm_release.cassandra",
            "helm_release.kube_prometheus_stack",
            "helm_release.redis",
            "null_resource.kind_cluster"
          ]
        }
      ]
    },
    {
      "mode": "managed",
      "type": "helm_release",
      "name": "otel_collector",
      "provider": "provider[\"registry.terraform.io/hashicorp/helm\"]",
      "instances": [
        {
          "schema_version": 1,
          "attributes": {
            "atomic": false,
            "chart": "opentelemetry-collector",
            "cleanup_on_fail": false,
            "create_namespace": true,
            "dependency_update": false,
            "description": null,
            "devel": null,
            "disable_crd_hooks": false,
            "disable_openapi_validation": false,
            "disable_webhooks": false,
            "force_update": false,
            "id": "otel-collector",
            "keyring": null,
            "lint": false,
            "manifest": null,
            "max_history": 0,
            "metadata": [
              {
                "app_version": "0.152.0",
                "chart": "opentelemetry-collector",
                "first_deployed": 1779947287,
                "last_deployed": 1779947287,
                "name": "otel-collector",
                "namespace": "monitoring",
                "notes": "\n\n\n",
                "revision": 1,
                "values": "{\"clusterRole\":{\"create\":true,\"rules\":[{\"apiGroups\":[\"\"],\"resources\":[\"pods\",\"namespaces\",\"nodes\",\"services\",\"endpoints\",\"replicationcontrollers\"],\"verbs\":[\"get\",\"list\",\"watch\"]},{\"apiGroups\":[\"apps\"],\"resources\":[\"deployments\",\"replicasets\",\"statefulsets\",\"daemonsets\"],\"verbs\":[\"get\",\"list\",\"watch\"]},{\"apiGroups\":[\"batch\"],\"resources\":[\"jobs\",\"cronjobs\"],\"verbs\":[\"get\",\"list\",\"watch\"]}]},\"config\":{\"exporters\":{\"debug\":{\"sampling_initial\":5,\"sampling_thereafter\":200,\"verbosity\":\"basic\"},\"otlp/tempo\":{\"compression\":\"gzip\",\"endpoint\":\"tempo.monitoring.svc:4317\",\"tls\":{\"insecure\":true}},\"otlphttp/loki\":{\"endpoint\":\"http://loki-gateway.monitoring.svc.cluster.local/otlp\",\"tls\":{\"insecure\":true}},\"prometheusremotewrite\":{\"endpoint\":\"http://kube-prometheus-stack-prometheus.monitoring.svc:9090/api/v1/write\",\"resource_to_telemetry_conversion\":{\"enabled\":true},\"tls\":{\"insecure\":true}}},\"processors\":{\"batch\":{\"send_batch_max_size\":2048,\"send_batch_size\":1024,\"timeout\":\"5s\"},\"filter/drop_health\":{\"error_mode\":\"ignore\",\"metrics\":{\"metric\":[\"name == \\\"up\\\" and IsMatch(resource.attributes[\\\"job\\\"], \\\".*health.*\\\")\"]},\"traces\":{\"span\":[\"attributes[\\\"http.route\\\"] == \\\"/health\\\"\",\"attributes[\\\"http.route\\\"] == \\\"/healthz\\\"\",\"attributes[\\\"http.route\\\"] == \\\"/actuator/health\\\"\",\"attributes[\\\"http.route\\\"] == \\\"/metrics\\\"\"]}},\"k8sattributes\":{\"auth_type\":\"serviceAccount\",\"passthrough\":false},\"memory_limiter\":{\"check_interval\":\"5s\",\"limit_mib\":400,\"spike_limit_mib\":100},\"resource\":{\"attributes\":[{\"action\":\"insert\",\"key\":\"cluster\",\"value\":\"kind-social-media\"},{\"action\":\"insert\",\"key\":\"environment\",\"value\":\"local\"}]}},\"receivers\":{\"hostmetrics\":{\"collection_interval\":\"30s\",\"scrapers\":{\"cpu\":{},\"disk\":{},\"filesystem\":{},\"load\":{},\"memory\":{},\"network\":{},\"processes\":{}}},\"k8s_cluster\":{\"collection_interval\":\"30s\"},\"otlp\":{\"protocols\":{\"grpc\":{\"endpoint\":\"0.0.0.0:4317\"},\"http\":{\"cors\":{\"allowed_origins\":[\"*\"]},\"endpoint\":\"0.0.0.0:4318\"}}},\"prometheus\":{\"config\":{\"scrape_configs\":[{\"job_name\":\"otel-collector-self\",\"scrape_interval\":\"15s\",\"static_configs\":[{\"targets\":[\"localhost:8888\"]}]}]}}},\"service\":{\"pipelines\":{\"logs\":{\"exporters\":[\"otlphttp/loki\"],\"processors\":[\"memory_limiter\",\"k8sattributes\",\"resource\",\"batch\"],\"receivers\":[\"otlp\"]},\"metrics\":{\"exporters\":[\"prometheusremotewrite\"],\"processors\":[\"memory_limiter\",\"k8sattributes\",\"resource\",\"batch\"],\"receivers\":[\"otlp\",\"prometheus\",\"hostmetrics\",\"k8s_cluster\"]},\"traces\":{\"exporters\":[\"otlp/tempo\"],\"processors\":[\"memory_limiter\",\"k8sattributes\",\"resource\",\"filter/drop_health\",\"batch\"],\"receivers\":[\"otlp\"]}},\"telemetry\":{\"logs\":{\"level\":\"info\"},\"metrics\":{\"level\":\"detailed\",\"readers\":[{\"pull\":{\"exporter\":{\"prometheus\":{\"host\":\"0.0.0.0\",\"port\":8888}}}}]}}}},\"extraEnvs\":[{\"name\":\"KUBE_NODE_NAME\",\"valueFrom\":{\"fieldRef\":{\"fieldPath\":\"spec.nodeName\"}}}],\"image\":{\"repository\":\"otel/opentelemetry-collector-contrib\",\"tag\":\"\"},\"mode\":\"deployment\",\"ports\":{\"metrics\":{\"containerPort\":8888,\"enabled\":true,\"protocol\":\"TCP\",\"servicePort\":8888},\"otlp\":{\"containerPort\":4317,\"enabled\":true,\"protocol\":\"TCP\",\"servicePort\":4317},\"otlp-http\":{\"containerPort\":4318,\"enabled\":true,\"protocol\":\"TCP\",\"servicePort\":4318},\"prometheus\":{\"containerPort\":8889,\"enabled\":true,\"protocol\":\"TCP\",\"servicePort\":8889},\"zipkin\":{\"containerPort\":9411,\"enabled\":true,\"protocol\":\"TCP\",\"servicePort\":9411}},\"replicaCount\":1,\"resources\":{\"limits\":{\"cpu\":\"500m\",\"memory\":\"512Mi\"},\"requests\":{\"cpu\":\"100m\",\"memory\":\"256Mi\"}},\"serviceAccount\":{\"create\":true},\"serviceMonitor\":{\"enabled\":true,\"extraLabels\":{\"release\":\"kube-prometheus-stack\"},\"metricsEndpoints\":[{\"interval\":\"30s\",\"port\":\"metrics\"}]}}",
                "version": "0.157.0"
              }
            ],
            "name": "otel-collector",
            "namespace": "monitoring",
            "pass_credentials": false,
            "postrender": [],
            "recreate_pods": false,
            "render_subchart_notes": true,
            "replace": false,
            "repository": "https://open-telemetry.github.io/opentelemetry-helm-charts",
            "repository_ca_file": null,
            "repository_cert_file": null,
            "repository_key_file": null,
            "repository_password": null,
            "repository_username": null,
            "reset_values": false,
            "reuse_values": false,
            "set": [],
            "set_list": [],
            "set_sensitive": [],
            "skip_crds": false,
            "status": "deployed",
            "timeout": 300,
            "upgrade_install": null,
            "values": [
              "# otel-collector-values.yml — kind-side OTEL Collector\n# Receives OTLP from apps/gateway, enriches with k8s metadata,\n# forwards to Prometheus, Loki, and Tempo.\n\nmode: deployment\nreplicaCount: 1\n\nimage:\n  repository: otel/opentelemetry-collector-contrib\n  tag: \"\"\n\nresources:\n  requests:\n    cpu: 100m\n    memory: 256Mi\n  limits:\n    cpu: 500m\n    memory: 512Mi\n\nports:\n  otlp:\n    enabled: true\n    containerPort: 4317\n    servicePort: 4317\n    protocol: TCP\n  otlp-http:\n    enabled: true\n    containerPort: 4318\n    servicePort: 4318\n    protocol: TCP\n  metrics:\n    enabled: true\n    containerPort: 8888\n    servicePort: 8888\n    protocol: TCP\n  zipkin:\n    enabled: true\n    containerPort: 9411\n    servicePort: 9411\n    protocol: TCP\n  prometheus:\n    enabled: true\n    containerPort: 8889\n    servicePort: 8889\n    protocol: TCP\n\nconfig:\n  receivers:\n    otlp:\n      protocols:\n        grpc:\n          endpoint: \"0.0.0.0:4317\"\n        http:\n          endpoint: \"0.0.0.0:4318\"\n          cors:\n            allowed_origins: [\"*\"]\n\n    # FIX: Removed docker service targets (notes-backend, bank-backend, etc.)\n    # Those are Docker containers on the host network — unreachable from inside kind.\n    # They are scraped by the otel-gateway Docker container instead.\n    # This receiver now only scrapes the collector's own self-metrics.\n    prometheus:\n      config:\n        scrape_configs:\n          - job_name: otel-collector-self\n            scrape_interval: 15s\n            static_configs:\n              - targets: [\"localhost:8888\"]\n\n    # hostmetrics runs inside a container — it reflects container-level\n    # metrics only, not the full node. Kept for basic process/memory insight.\n    hostmetrics:\n      collection_interval: 30s\n      scrapers:\n        cpu: {}\n        memory: {}\n        disk: {}\n        filesystem: {}\n        network: {}\n        load: {}\n        processes: {}\n\n    k8s_cluster:\n      collection_interval: 30s\n\n  processors:\n    batch:\n      timeout: 5s\n      send_batch_size: 1024\n      send_batch_max_size: 2048\n\n    filter/drop_health:\n      error_mode: ignore\n      traces:\n        span:\n          - 'attributes[\"http.route\"] == \"/health\"'\n          - 'attributes[\"http.route\"] == \"/healthz\"'\n          - 'attributes[\"http.route\"] == \"/actuator/health\"'\n          - 'attributes[\"http.route\"] == \"/metrics\"'\n      metrics:\n        metric:\n          # FIX: =~ is not valid OTTL — use IsMatch() for regex\n          - 'name == \"up\" and IsMatch(resource.attributes[\"job\"], \".*health.*\")'\n\n    k8sattributes:\n      auth_type: serviceAccount\n      passthrough: false\n\n    resource:\n      attributes:\n        - key: cluster\n          value: kind-social-media\n          action: insert\n        - key: environment\n          value: local\n          action: insert\n\n    memory_limiter:\n      check_interval: 5s\n      limit_mib: 400\n      spike_limit_mib: 100\n\n  exporters:\n    prometheusremotewrite:\n      endpoint: http://kube-prometheus-stack-prometheus.monitoring.svc:9090/api/v1/write\n      tls:\n        insecure: true\n      resource_to_telemetry_conversion:\n        enabled: true\n\n    otlphttp/loki:\n      endpoint: http://loki-gateway.monitoring.svc.cluster.local/otlp\n      tls:\n        insecure: true\n\n    otlp/tempo:\n      endpoint: tempo.monitoring.svc:4317\n      tls:\n        insecure: true\n      compression: gzip\n\n    debug:\n      verbosity: basic\n      sampling_initial: 5\n      sampling_thereafter: 200\n\n  service:\n    telemetry:\n      logs:\n        level: info\n      # FIX: metrics.address is deprecated and removed in newer collector versions.\n      # Use readers with a pull exporter instead.\n      metrics:\n        level: detailed\n        readers:\n          - pull:\n              exporter:\n                prometheus:\n                  host: \"0.0.0.0\"\n                  port: 8888\n\n    pipelines:\n      traces:\n        receivers: [otlp]\n        processors: [memory_limiter, k8sattributes, resource, filter/drop_health, batch]\n        exporters: [otlp/tempo]\n\n      metrics:\n        receivers: [otlp, prometheus, hostmetrics, k8s_cluster]\n        processors: [memory_limiter, k8sattributes, resource, batch]\n        exporters: [prometheusremotewrite]\n\n      logs:\n        receivers: [otlp]\n        processors: [memory_limiter, k8sattributes, resource, batch]\n        exporters: [otlphttp/loki]\n\n# FIX: Added full RBAC rules required by k8sattributes processor\n# and k8s_cluster receiver — default ClusterRole is too restrictive.\nclusterRole:\n  create: true\n  rules:\n    - apiGroups: [\"\"]\n      resources:\n        - pods\n        - namespaces\n        - nodes\n        - services\n        - endpoints\n        - replicationcontrollers\n      verbs: [\"get\", \"list\", \"watch\"]\n    - apiGroups: [\"apps\"]\n      resources:\n        - deployments\n        - replicasets\n        - statefulsets\n        - daemonsets\n      verbs: [\"get\", \"list\", \"watch\"]\n    - apiGroups: [\"batch\"]\n      resources:\n        - jobs\n        - cronjobs\n      verbs: [\"get\", \"list\", \"watch\"]\n\nserviceAccount:\n  create: true\n\nextraEnvs:\n  - name: KUBE_NODE_NAME\n    valueFrom:\n      fieldRef:\n        fieldPath: spec.nodeName\n\nserviceMonitor:\n  enabled: true\n  metricsEndpoints:\n    - port: metrics\n      interval: 30s\n  extraLabels:\n    release: kube-prometheus-stack"
            ],
            "verify": false,
            "version": "0.157.0",
            "wait": true,
            "wait_for_jobs": false
          },
          "sensitive_attributes": [
            [
              {
                "type": "get_attr",
                "value": "repository_password"
              }
            ]
          ],
          "identity_schema_version": 0,
          "private": "eyJzY2hlbWFfdmVyc2lvbiI6IjEifQ==",
          "dependencies": [
            "helm_release.cassandra",
            "helm_release.kube_prometheus_stack",
            "helm_release.loki",
            "helm_release.redis",
            "helm_release.tempo",
            "kubectl_manifest.minio_service",
            "null_resource.kind_cluster"
          ]
        }
      ]
    },
