            "id": "tempo",
            "keyring": null,
            "lint": false,
            "manifest": null,
            "max_history": 0,
            "metadata": [
              {
                "app_version": "2.9.0",
                "chart": "tempo",
                "first_deployed": 1779938515,
                "last_deployed": 1779946585,
                "name": "tempo",
                "namespace": "monitoring",
                "notes": "",
                "revision": 5,
                "values": "{\"persistence\":{\"enabled\":true,\"size\":\"5Gi\",\"storageClassName\":\"standard\"},\"resources\":{\"limits\":{\"cpu\":\"1000m\",\"memory\":\"1Gi\"},\"requests\":{\"cpu\":\"200m\",\"memory\":\"256Mi\"}},\"service\":{\"port\":3200,\"type\":\"ClusterIP\"},\"serviceAccount\":{\"create\":true},\"serviceMonitor\":{\"enabled\":true,\"interval\":\"30s\",\"labels\":{\"release\":\"kube-prometheus-stack\"}},\"tempo\":{\"compactor\":{\"compaction\":{\"block_retention\":\"336h\"}},\"distributor\":{\"receivers\":{\"jaeger\":{\"protocols\":{\"grpc\":{\"endpoint\":\"0.0.0.0:14250\"},\"thrift_http\":{\"endpoint\":\"0.0.0.0:14268\"}}},\"otlp\":{\"protocols\":{\"grpc\":{\"endpoint\":\"0.0.0.0:4317\"},\"http\":{\"endpoint\":\"0.0.0.0:4318\"}}},\"zipkin\":{\"endpoint\":\"0.0.0.0:9411\"}}},\"global_overrides\":{\"metrics_generator_processors\":[\"service-graphs\",\"span-metrics\"]},\"ingester\":{\"max_block_duration\":\"5m\"},\"metrics_generator\":{\"processor\":{\"service_graphs\":{\"dimensions\":[\"http.method\",\"http.status_code\",\"service.name\"],\"enable_messaging_system_latency_histogram\":true},\"span_metrics\":{\"dimensions\":[\"http.method\",\"http.status_code\",\"http.route\",\"service.name\"]}},\"registry\":{\"external_labels\":{\"cluster\":\"kind-social-media\",\"source\":\"tempo\"}},\"storage\":{\"path\":\"/var/tempo/generator/wal\"},\"traces_storage\":{\"path\":\"/var/tempo/generator/traces\"}},\"querier\":{\"max_concurrent_queries\":10},\"server\":{\"grpc_listen_port\":9095,\"http_listen_port\":3200,\"log_level\":\"info\"},\"storage\":{\"trace\":{\"backend\":\"local\",\"local\":{\"path\":\"/var/tempo/traces\"},\"wal\":{\"path\":\"/var/tempo/wal\"}}}},\"values_sha\":\"(sensitive value)\"}",
                "version": "1.24.4"
              }
            ],
            "name": "tempo",
            "namespace": "monitoring",
            "pass_credentials": false,
            "postrender": [],
            "recreate_pods": false,
            "render_subchart_notes": true,
            "replace": false,
            "repository": "https://grafana.github.io/helm-charts",
            "repository_ca_file": null,
            "repository_cert_file": null,
            "repository_key_file": null,
            "repository_password": null,
            "repository_username": null,
            "reset_values": false,
            "reuse_values": false,
            "set": [],
            "set_list": [],
            "set_sensitive": [
              {
                "name": "values_sha",
                "type": "",
                "value": "MjNqEoQm3f7CXARnfim8F/i4EpEq7h4MNtmdCr1fJ6k="
              }
            ],
            "skip_crds": false,
            "status": "deployed",
            "timeout": 300,
            "upgrade_install": null,
            "values": [
              "# ─────────────────────────────────────────────────────────────\n# tempo-config.yml  — Helm values for grafana/tempo\n#\n# Deployed via:\n#   helm_release \"tempo\" { values = [file(\"…/tempo-config.yml\")] }\n#\n# Receives traces from the OTel Collector via OTLP/gRPC (4317)\n# and OTLP/HTTP (4318).  Stores on local filesystem for the\n# kind cluster.  Grafana reads traces and correlates with logs\n# via trace_id labels injected by Promtail/OTel.\n# ─────────────────────────────────────────────────────────────\n\ntempo:\n  # ── Server ────────────────────────────────────────────────\n  server:\n    http_listen_port: 3200\n    grpc_listen_port: 9095\n    log_level: info\n\n  # ── Distributor: which ingest endpoints to enable ─────────\n  distributor:\n    receivers:\n      otlp:\n        protocols:\n          grpc:\n            endpoint: \"0.0.0.0:4317\"\n          http:\n            endpoint: \"0.0.0.0:4318\"\n      # Also accept Zipkin spans from legacy services\n      zipkin:\n        endpoint: \"0.0.0.0:9411\"\n      # Jaeger for anything using the Jaeger client library\n      jaeger:\n        protocols:\n          thrift_http:\n            endpoint: \"0.0.0.0:14268\"\n          grpc:\n            endpoint: \"0.0.0.0:14250\"\n\n  # ── Ingester ──────────────────────────────────────────────\n  ingester:\n    max_block_duration: 5m    # flush frequently for low-latency local dev\n\n  # ── Storage (filesystem for kind) ─────────────────────────\n  storage:\n    trace:\n      backend: local\n      local:\n        path: /var/tempo/traces\n      wal:\n        path: /var/tempo/wal\n\n  # ── Compactor ─────────────────────────────────────────────\n  compactor:\n    compaction:\n      block_retention: 336h   # 14 days of traces\n\n  # ── Query-frontend ────────────────────────────────────────\n  querier:\n    max_concurrent_queries: 10\n\n  # ── Metrics-generator: derive RED metrics from traces ─────\n  # These land in Prometheus via remote_write and let you build\n  # service graphs and span metrics dashboards in Grafana.\n  metrics_generator:\n    registry:\n      external_labels:\n        source: tempo\n        cluster: kind-social-media\n    storage:\n      path: /var/tempo/generator/wal\n    traces_storage:\n      path: /var/tempo/generator/traces\n    processor:\n      # Service graph: request rate, error rate, latency between services\n      service_graphs:\n        dimensions:\n          - http.method\n          - http.status_code\n          - service.name\n        enable_messaging_system_latency_histogram: true\n      # Span metrics: per-span RED metrics\n      span_metrics:\n        dimensions:\n          - http.method\n          - http.status_code\n          - http.route\n          - service.name\n\n  global_overrides:\n    metrics_generator_processors:\n      - service-graphs\n      - span-metrics\n\n# ── Persistence ───────────────────────────────────────────────\npersistence:\n  enabled: true\n  storageClassName: standard\n  size: 5Gi\n\n# ── Resources ────────────────────────────────────────────────\nresources:\n  requests:\n    cpu: 200m\n    memory: 256Mi\n  limits:\n    cpu: 1000m\n    memory: 1Gi\n\n# ── Service ports (expose all receivers inside the cluster) ──\nservice:\n  type: ClusterIP\n  port: 3200\n\nserviceAccount:\n  create: true\n\n# ── Self-monitoring ───────────────────────────────────────────\nserviceMonitor:\n  enabled: true\n  labels:\n    release: kube-prometheus-stack\n  interval: 30s\n\n# ── Grafana datasource (added automatically if tempo-grafana\n#    sub-chart is not used; configure manually in Grafana) ────\n# Grafana → Settings → Data Sources → Tempo\n#   URL:  http://tempo:3200\n#   Trace to logs:\n#     Data source: Loki\n#     Tags:  service.name → app\n#   Trace to metrics:\n#     Data source: Prometheus"
            ],
            "verify": false,
            "version": "1.24.4",
            "wait": true,
            "wait_for_jobs": false
          },
          "sensitive_attributes": [
            [
              {
                "type": "get_attr",
                "value": "repository_password"
              }
            ],
            [
              {
                "type": "get_attr",
                "value": "set_sensitive"
              }
            ]
          ],
          "identity_schema_version": 0,
          "private": "eyJzY2hlbWFfdmVyc2lvbiI6IjEifQ==",
          "dependencies": [
            "helm_release.cassandra",
            "helm_release.kube_prometheus_stack",
            "helm_release.loki",
            "helm_release.redis",
            "kubectl_manifest.minio_service",
            "null_resource.kind_cluster"
          ]
        }
      ]
    },
