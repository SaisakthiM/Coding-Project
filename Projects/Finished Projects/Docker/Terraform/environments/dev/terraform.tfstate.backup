            "yaml_body": "apiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: backend\nspec:\n  replicas: 1\n  selector:\n    matchLabels:\n      app: backend\n  template:\n    metadata:\n      labels:\n        app: backend\n    spec:\n      containers:\n        - name: backend\n          image: socialmediaapp-django:latest\n          imagePullPolicy: Never\n          ports:\n            - containerPort: 8000\n          env:\n            - name: DB_NAME\n              value: socialdb\n            - name: DB_USER\n              value: admin\n            - name: DB_PASSWORD\n              value: password\n            - name: DB_HOST\n              value: postgres\n            - name: DB_PORT\n              value: \"5432\"\n            - name: DEBUG\n              value: \"True\"\n            - name: RUNNING_IN_DOCKER\n              value: \"True\"\n            - name: REDIS_PORT      \n              value: \"6379\"\n",
