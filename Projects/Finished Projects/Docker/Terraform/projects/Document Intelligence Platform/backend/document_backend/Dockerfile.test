FROM python:3.11-slim

RUN apt-get update && apt-get install -y \
    pkg-config \
    default-libmysqlclient-dev \
    gcc \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install only what's needed for tests — skip torch/sentence-transformers
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt \
    --extra-index-url https://download.pytorch.org/whl/cpu

ARG CACHE_BUST
COPY . .

ENV DJANGO_SETTINGS_MODULE=document_backend.test_settings \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

CMD ["sh", "-c", "python manage.py migrate --run-syncdb && python manage.py test document --verbosity=2"]