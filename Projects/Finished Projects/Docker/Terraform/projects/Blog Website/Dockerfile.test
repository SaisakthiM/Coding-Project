FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

ARG CACHE_BUST
COPY . .

ENV DJANGO_SETTINGS_MODULE=blogsite.settings \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# manage.py is inside blogsite/ subfolder
CMD ["sh", "-c", "cd blogsite && python manage.py migrate && python manage.py test blog.tests --verbosity=2"]