# Dockerfile.test — Python/Django, only for running tests, never deployed
FROM python:3.11-slim

WORKDIR /app

# Install deps first (cached layer)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy source
COPY . .

# Set environment variables for test environment
ENV DJANGO_SETTINGS_MODULE=notes_app.settings \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

RUN python manage.py migrate --run-syncdb

# Run tests — exits with code 1 if any test fails
CMD ["python", "manage.py", "test", "--verbosity=2"]