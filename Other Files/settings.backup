    // Executor map for all languages
    "code-runner.executorMap": {
        "c": "Set-Location -Path $dir ; if ($?) { gcc $fileName -o $fileNameWithoutExt } ; if ($?) { & (Join-Path $dir $fileNameWithoutExt) }",
        "cpp": "Set-Location -Path $dir ; if ($?) { g++ $fileName -o $fileNameWithoutExt } ; if ($?) { & (Join-Path $dir $fileNameWithoutExt) }",
        "java": "Set-Location -Path $dir ; if ($?) { javac $fileName } ; if ($?) { java $fileNameWithoutExt }",
        "python": "Set-Location -Path $dir ; if ($?) { python $fileName }",
        "javascript": "Set-Location -Path $dir ; if ($?) { node $fileName }",
        "typescript": "Set-Location -Path $dir ; if ($?) { ts-node $fileName }",
        "go": "Set-Location -Path $dir ; if ($?) { go run $fileName }",
        "ruby": "Set-Location -Path $dir ; if ($?) { ruby $fileName }",
        "php": "Set-Location -Path $dir ; if ($?) { php $fileName }",
        "perl": "Set-Location -Path $dir ; if ($?) { perl $fileName }",
        "rust": "Set-Location -Path $dir ; if ($?) { rustc $fileName } ; if ($?) { & (Join-Path $dir $fileNameWithoutExt) }",
        "swift": "Set-Location -Path $dir ; if ($?) { swift $fileName }",
        "kotlin": "Set-Location -Path $dir ; if ($?) { kotlinc $fileName -include-runtime -d $fileNameWithoutExt.jar } ; if ($?) { java -jar (Join-Path $dir \"$fileNameWithoutExt.jar\") }",
        "scala": "Set-Location -Path $dir ; if ($?) { scala $fileName }",
        "r": "Set-Location -Path $dir ; if ($?) { Rscript $fileName }",
        "bash": "Set-Location -Path $dir ; if ($?) { bash $fileName }",
        "powershell": "Set-Location -Path $dir ; if ($?) { & $fileName }",
        "nasm": "cd $(wslpath -a $(pwd)) && nasm -f elf64 $fileName -o $fileNameWithoutExt.o && ld $fileNameWithoutExt.o -o $fileNameWithoutExt && ./$fileNameWithoutExt",
        "asm-intel-x86-generic": "powershell -ExecutionPolicy Bypass -File \"C:/Coding Project/run-asm.ps1\""
    },
    
    
