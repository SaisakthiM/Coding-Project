{
    // -------------------------------
    // Appearance & UI
    // -------------------------------
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairsHorizontal": false,
    "editor.guides.bracketPairs": true,
    "editor.guides.indentation": true,

    "workbench.colorCustomizations": {
    "list.deemphasizedForeground": "#0000FF80",
    // ===== Terminal =====
    "terminal.background": "#0f1117",
    "terminal.foreground": "#b3eaff",
    "terminal.ansiBlack": "#1b1d23",
    "terminal.ansiRed": "#e06c75",
    "terminal.ansiGreen": "#7fd0c3",
    "terminal.ansiYellow": "#e0dcbf",
    "terminal.ansiBlue": "#88cfff",
    "terminal.ansiMagenta": "#a9a1e1",
    "terminal.ansiCyan": "#9de2f9",
    "terminal.ansiWhite": "#e6f7ff",
    "terminal.ansiBrightBlack": "#3c4048",
    "terminal.ansiBrightRed": "#ff8e91",
    "terminal.ansiBrightGreen": "#a4f9dd",
    "terminal.ansiBrightYellow": "#f9f5c7",
    "terminal.ansiBrightBlue": "#c2f0ff",
    "terminal.ansiBrightMagenta": "#c5b4e3",
    "terminal.ansiBrightCyan": "#d2f8ff",
    "terminal.ansiBrightWhite": "#f3fdff",

    // ===== Bracket Highlight Colors =====
    "editorBracketHighlight.foreground1": "#89b4fa",
    "editorBracketHighlight.foreground2": "#94e2d5",
    "editorBracketHighlight.foreground3": "#f9e2af",
    "editorBracketHighlight.foreground4": "#f38ba8",
    "editorBracketHighlight.foreground5": "#cba6f7",
    "editorBracketHighlight.foreground6": "#a6e3f1",
    "editorBracketHighlight.unexpectedBracket.foreground": "#ff5555",

    // ===== Bracket Pair Guides (make them bolder by higher contrast + semi-opaque) =====
    "editorBracketPairGuide.activeBackground1": "#89b4faAA",
    "editorBracketPairGuide.activeBackground2": "#94e2d5AA",
    "editorBracketPairGuide.activeBackground3": "#f9e2afAA",
    "editorBracketPairGuide.activeBackground4": "#f38ba8AA",
    "editorBracketPairGuide.activeBackground5": "#cba6f7AA",
    "editorBracketPairGuide.activeBackground6": "#a6e3f1AA",

    "editorBracketPairGuide.background1": "#89b4fa77",
    "editorBracketPairGuide.background2": "#94e2d577",
    "editorBracketPairGuide.background3": "#f9e2af77",
    "editorBracketPairGuide.background4": "#f38ba877",
    "editorBracketPairGuide.background5": "#cba6f777",
    "editorBracketPairGuide.background6": "#a6e3f177",

    // ===== Indent Guides (helps fake thickness) =====
    "editorIndentGuide.background1": "#44444499",          // faint
    "editorIndentGuide.activeBackground1": "#00e0ffDD",    // neon cyan, strong

    // ===== Selections =====
    "editor.selectionBackground": "#5ec6ff55",
    "editor.selectionHighlightBackground": "#5ec6ff33",

    // ===== Line Highlight =====
    "editor.lineHighlightBackground": "#1073cf2d",
    "editor.lineHighlightBorder": "#9fced11f",
    
},
    // ===== Disable old extensions that might conflict =====
    "extensions.ignoreRecommendations": false,
    "indentRainbow.colors": [
        "rgba(129,161,193,0.1)", // blue (#81a1c1)
        "rgba(163,190,140,0.1)", // green (#a3be8c)
        "rgba(180,142,173,0.1)", // purple (#b48ead)
        "rgba(136,192,208,0.1)", // cyan (#88c0d0)
        "rgba(216,222,233,0.1)", // light grey (#d8dee9)
        "rgba(94,129,172,0.1)",  // dark blue (#5e81ac)
        "rgba(143,188,187,0.1)"  // teal (#8fbcbb)
    ],

    "indentRainbow.errorColor": "rgba(94,129,172,0.6)", 
    "workbench.iconTheme": "material-icon-theme",

    // -------------------------------
    // Language & File Associations
    // -------------------------------
    "files.associations": {
        "*.css": "css",
        "*.asm": "asm-intel-x86-generic",
        "*.html": "html"
    },
    "files.watcherExclude": {
        "**/node_modules/**": true,
        "**/dist/**": true,
        "**/build/**": true,
        "**/.venv/**": true,
        "**/__pycache__/**": true,
        "**/*.log": true
    },
    "search.exclude": {
    "**/*": true,            // Exclude everything by default
    "**/*.c": false,
    "**/*.cpp": false,
    "**/*.h": false,
    "**/*.py": false,
    "**/*.java": false,
    "**/*.js": false,
    "**/*.ts": false,
    "**/*.go": false,
    "**/*.rb": false,
    "**/*.php": false,
    "**/*.pl": false,
    "**/*.rs": false,
    "**/*.swift": false,
    "**/*.kt": false,
    "**/*.scala": false,
    "**/*.r": false,
    "**/*.sh": false,
    "**/*.ps1": false,
    "**/*.asm": false,
    "**/media/**": false      // keep media folder indexed if needed
},
    "workbench.editorAssociations": {
        "*.copilotmd": "vscode.markdown.preview.editor",
        "*.html": "default",
        "*.lnk": "default"
    },
    "[html]": {
        "editor.defaultFormatter": "vscode.html-language-features"
    },
    "[java]": {
        "editor.defaultFormatter": "redhat.java"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[python]": {
        "editor.defaultFormatter": null
    },
    "[csv]": {
        "editor.inlayHints.maximumLength": 0
    },

    // -------------------------------
    // Python Settings
    // -------------------------------
    "python.defaultInterpreterPath": "c:\\Coding Project\\.venv-13\\Scripts\\python.exe",
    "python.analysis.autoImportCompletions": false,
    "python.analysis.indexing": false,
    "python.analysis.extraPaths": [
        "./src"
    ],
    "python.languageServer": "Pylance",
    "python.experiments.enabled": false,
    "python.analysis.completeFunctionParens": false,
    "python.linting.enabled": false,
    "python.createEnvironment.contentButton": "show",
    "python.terminal.activateEnvInCurrentTerminal": true,
    "python.globalModuleInstallation": true,

    // Black Formatter
    "black-formatter.path": "c:\\Coding Project\\.venv-13\\Scripts\\black.exe",
    "black-formatter.interpreter": "c:\\Coding Project\\.venv-13\\Scripts\\python.exe",
    
    // -------------------------------
    // Editor Behavior
    // -------------------------------
    "editor.fontFamily": "Jetbrains Mono,Consolas, 'Courier New', monospace",
    "editor.fontLigatures": true,
    "editor.smoothScrolling": true,
    "editor.mouseWheelZoom": true,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    
    "editor.linkedEditing": true,
    "editor.quickSuggestions": {
        "comments": "off",
        "strings": "off"
    },
    "editor.suggestOnTriggerCharacters": true,
    "editor.suggestSelection": "first",
    "editor.snippetSuggestions": "none",
    "editor.inlineSuggest.enabled": false,
    "editor.tokenColorCustomizations": {
    "textMateRules": [
        {
            "scope": [
                "comment",
                "comment.block",
                "comment.line",
                "comment.block.documentation"
            ],
            "settings": {
                "foreground": "#4FC1E9", // Icy sky-blue comments
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "source",
                "meta.embedded",
                "meta.block",
                "meta.function"
            ],
            "settings": {
                "foreground": "#FFFFFF" // ❄️ Snow white base text
            }
        },
        {
            "scope": [
                "variable",
                "variable.other",
                "variable.other.readwrite",
                "meta.definition.variable.name",
                "meta.definition.parameter",
                "support.variable"
            ],
            "settings": {
                "foreground": "#40E0D0" // ✨ Bright turquoise variables
            }
        },
        {
            "scope": [
                "entity.name.function",
                "support.function"
            ],
            "settings": {
                "foreground": "#00F5FF", // Neon cyan functions
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "keyword",
                "keyword.control",
                "storage.type"
            ],
            "settings": {
                "foreground": "#7A5FFF", // Bold violet keywords
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "string",
                "string.quoted",
                "string.template"
            ],
            "settings": {
                "foreground": "#6BEF6B" // Bright ice-green strings
            }
        },
        {
            "scope": [
                "constant.numeric",
                "constant.language",
                "constant.character"
            ],
            "settings": {
                "foreground": "#2ECCFA" // Vibrant aqua numbers
            }
        },
        {
            "scope": [
                "support.type",
                "entity.name.type",
                "meta.type"
            ],
            "settings": {
                "foreground": "#00D0FF" // Electric blue types
            }
        },
        {
            "scope": [
                "support.class",
                "entity.name.class"
            ],
            "settings": {
                "foreground": "#00D9B5", // Bright turquoise classes
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "meta.object-literal.key",
                "support.type.property-name",
                "entity.name.property"
            ],
            "settings": {
                "foreground": "#12CAD6" // 🌟 Warm yellow object properties
            }
        },
        {
            "scope": [
                "punctuation.definition.tag",
                "punctuation.separator",
                "punctuation.terminator"
            ],
            "settings": {
                "foreground": "#5BC0DE" // Light cyan punctuation
            }
        }
    ]
},

