# =========================================
# Turbo Continue Ignore for Huge Projects
# =========================================

# Ignore all files by default
exclude:
  - "**/*"

# Only include source code files you want Continue to track
include:
  # JavaScript / TypeScript
  - "**/*.js"
  - "**/*.ts"
  - "**/*.jsx"
  - "**/*.tsx"

  # Python
  - "**/*.py"

  # HTML / CSS
  - "**/*.html"
  - "**/*.css"

  # Django / Flask templates
  - "**/*.jinja"
  - "**/*.django"
  - "**/*.tpl"

# Optional: include config files if needed for context
# - "package.json"
# - "requirements.txt"
# - "**/settings.py"

# Everything else is ignored (logs, node_modules, build output, etc.)
