{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "jdk",
      "name": "Java: SaiApplication",
      "request": "launch",
      "mainClass": "com.generics.sai.SaiApplication"
    },
    {
      "type": "jdk",
      "name": "Java: Others",
      "request": "launch",
      "mainClass": "Exercises.Others.Others"
    },
    {
      "type": "jdk",
      "name": "Spring Boot: SaisakthiApplication",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "mainClass": "spring_boot.saisakthi.SaisakthiApplication",
      "args": ""
    },
    {
      "type": "jdk",
      "name": "Spring Boot: Application2",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "mainClass": "spring_project.spring.Application2",
      "args": ""
    },
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "C: Debug Current File",
      "type": "cppdbg",
      "request": "launch",
      "program": "${fileDirname}/${fileBasenameNoExtension}",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${fileDirname}",
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "preLaunchTask": "C: gcc build active file",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "C++: Debug Current File",
      "type": "cppdbg",
      "request": "launch",
      "program": "${fileDirname}/${fileBasenameNoExtension}",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${fileDirname}",
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "preLaunchTask": "C++: g++ build active file",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "C++: Build & Debug Folder",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/.vscode/build/out",
      "args": [],
      "stopAtEntry": true,
      "cwd": "${input:cppFolderPath}",
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "preLaunchTask": "C++: build folder (custom path)",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "C++: CLion project",
      "type": "cppdbg",
      "request": "launch",
      "program": "/home/saisakthi/Coding-Project/Programming Languages/Clion C Family/C++/Tasks/build/Debug/outDebug",
      "args": [],
      "stopAtEntry": false,
      "cwd": "/home/saisakthi/Coding-Project/Programming Languages/Clion C Family/C++/Tasks",
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "Go: Launch Package",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${fileDirname}"
    },
    {
      "name": "Go: Test Current File",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}"
    },
    {
      "name": "Rust: cargo run",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": [
          "build",
          "--bin=${workspaceFolderBasename}"
        ]
      },
      "args": [],
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Rust: cargo test",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": [
          "test",
          "--no-run",
          "--lib"
        ]
      },
      "args": [],
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "C/C++ Runner: Debug Session",
      "type": "cppdbg",
      "request": "launch",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": false,
      "cwd": "/home/saisakthi/Coding-Project",
      "program": "/home/saisakthi/Coding-Project/build/Debug/outDebug",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ],
  "inputs": [
    {
      "id": "cppFolderPath",
      "type": "promptString",
      "description": "Path to the folder containing your .cpp files (e.g. /home/saisakthi/project/src)",
      "default": "${fileDirname}"
    }
  ]
}